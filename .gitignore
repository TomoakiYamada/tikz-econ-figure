# ============================================================
#  .gitignore for upLaTeX + Beamer + TikZ projects
# ============================================================

# ============================================================
#  LaTeX 補助ファイル（コンパイル時に自動生成されるもの）
# ============================================================
*.aux
*.log
*.toc
*.nav
*.snm
*.out
*.vrb
*.fls
*.fdb_latexmk
*.synctex.gz
*.synctex(busy)
*.bbl
*.blg
*.dvi

# ============================================================
#  PDF（コンパイル生成物）
# ============================================================
# tikz/ 以下の単体コンパイル PDF は除外
tikz/*.pdf

# メインの出力 PDF もバージョン管理から除外する場合は以下を有効化:
# *.pdf

# ============================================================
#  macOS
# ============================================================
.DS_Store
.AppleDouble
.LSOverride

# ============================================================
#  Windows
# ============================================================
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================================
#  エディタ・IDE
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# TeXpad（macOS）
.texpadtmp/

# TexShop
*.pdfsync
